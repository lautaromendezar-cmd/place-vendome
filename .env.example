# Copiá este archivo a .env.local y completá los valores.
# En Vercel, los mismos van en Settings → Environment Variables.

# --- Sanity (el panel de contenido) ---
# Los dos primeros los ves en sanity.io/manage, dentro del proyecto.
# No son secretos: viajan al navegador (por eso el prefijo NEXT_PUBLIC).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Token con permiso de escritura. SOLO para la carga inicial (npm run sanity:seed).
# Se crea en sanity.io/manage → API → Tokens, con rol "Editor".
# NO hace falta cargarlo en Vercel: el sitio solo lee.
SANITY_API_WRITE_TOKEN=

# Cualquier cadena larga inventada. La misma va acá y en el webhook de Sanity
# (sanity.io/manage → API → Webhooks). Sirve para que nadie más pueda pedir
# una revalidación haciéndose pasar por Sanity.
SANITY_REVALIDATE_SECRET=

# --- Sitio ---
# El dominio final, para que las previews de WhatsApp/Google apunten bien.
NEXT_PUBLIC_SITE_URL=https://placevendome.com.ar

# --- Formularios (Contacto y Catálogo) ---
# Los formularios mandan las consultas por mail usando el SMTP de Hostinger,
# con la casilla del emprendimiento (se crea en hPanel → Emails).
# La casilla se manda los mails a sí misma; responder desde ahí le contesta
# directo al interesado (el mail del visitante va en Reply-To).
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=contacto@placevendome.com.ar
SMTP_PASS=
